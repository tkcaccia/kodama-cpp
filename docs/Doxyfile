PROJECT_NAME           = "kodama-cpp"
PROJECT_BRIEF          = "Standalone float32 KODAMA kernels for CPU, CUDA, and Apple Metal"
OUTPUT_DIRECTORY       = docs/api
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = docs/mainpage.md
INPUT                  = docs/mainpage.md docs/getting-started.md docs/r-api.md docs/coverage.md include/kodama
FILE_PATTERNS           = *.md *.hpp
RECURSIVE               = YES
EXTRACT_ALL             = YES
EXTRACT_PRIVATE         = NO
EXTRACT_STATIC          = NO
SOURCE_BROWSER          = YES
INLINE_SOURCES          = NO
STRIP_FROM_PATH         = .
GENERATE_HTML           = YES
HTML_OUTPUT             = html
GENERATE_LATEX          = NO
GENERATE_TREEVIEW       = YES
DISABLE_INDEX           = NO
FULL_SIDEBAR            = NO
HAVE_DOT                = YES
DOT_IMAGE_FORMAT        = svg
INTERACTIVE_SVG         = YES
QUIET                   = NO
WARNINGS                = YES
WARN_IF_UNDOCUMENTED    = YES
WARN_AS_ERROR           = NO
